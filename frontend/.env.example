# -----------------------------------------------------------------------
# VITE_API_URL — Optional override for the API base URL
#
# Leave UNSET (commented out) when using the Vite proxy (default for both
# local dev and Docker). The browser will call /api/* and the Vite dev
# server proxy will forward to the backend.
#
# Set this ONLY if you bypass the Vite proxy entirely and point the
# browser directly at the backend (e.g. a deployed API):
#   VITE_API_URL=https://my-api.example.com
#
# For local dev:  leave commented out (proxy target = http://localhost:8000)
# For Docker:     leave commented out (proxy target = http://api:8000 via API_TARGET_URL)
# -----------------------------------------------------------------------
# VITE_API_URL=http://localhost:8000
